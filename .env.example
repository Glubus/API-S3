# === Server Configuration (Axum / Tokio) ===
# Log level: error, warn, info, debug, trace
RUST_LOG=info

# === Local Storage (Fallback) ===
# Path to local image assets directory (used when USE_S3=false)
IMAGE_DIR=assets/images

# === MinIO / S3 Configuration ===
# Enable S3 storage backend (true/false — false falls back to local filesystem)
USE_S3=false
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio-admin
S3_SECRET_KEY=minio-admin
S3_BUCKET=images
S3_REGION=us-east-1

# === OpenTelemetry / Jaeger ===
# gRPC OTLP collector endpoint (port 4317 = OTLP gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://your-super-jaeger.net:4317
OTEL_SERVICE_NAME=YOUR_AWESOME_OTEL_SERVICE
